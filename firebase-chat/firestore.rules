rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /rooms/{roomId}/messages/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.senderId is string
        && request.resource.data.readAt == null;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readAt']);
      allow delete: if false;
    }

    match /typingSessions/{sessionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.participantId is string
        && request.resource.data.roomId is string
        && request.resource.data.deltaT is int
        && request.resource.data.sessionStartTime is int
        && request.resource.data.sessionEndTime is int
        && request.resource.data.endReason is string
        && request.resource.data.totalTypingMs is int
        && request.resource.data.totalPauseMs is int
        && request.resource.data.totalMaskedMs is int
        && request.resource.data.raw is map
        && request.resource.data.processed is map;
      allow update, delete: if false;
    }
  }
}
